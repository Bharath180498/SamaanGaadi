generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  DRIVER
  ADMIN
}

enum VehicleType {
  THREE_WHEELER
  MINI_TRUCK
  TRUCK
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AvailabilityStatus {
  OFFLINE
  ONLINE
  BUSY
}

enum OrderStatus {
  CREATED
  MATCHING
  ASSIGNED
  AT_PICKUP
  LOADING
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum InsurancePlan {
  NONE
  BASIC
  PREMIUM
  HIGH_VALUE
}

enum TripStatus {
  ASSIGNED
  DRIVER_EN_ROUTE
  ARRIVED_PICKUP
  LOADING
  IN_TRANSIT
  COMPLETED
  CANCELLED
}

enum PaymentProvider {
  RAZORPAY
  STRIPE
  UPI
  WALLET
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
}

model User {
  id           String         @id @default(uuid())
  name         String
  phone        String         @unique
  email        String?        @unique
  passwordHash String?
  role         UserRole
  rating       Float          @default(5)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  customerOrders Order[]      @relation("CustomerOrders")
  driverProfile  DriverProfile?
}

model DriverProfile {
  id                 String             @id @default(uuid())
  userId             String             @unique
  vehicleType        VehicleType
  vehicleNumber      String             @unique
  licenseNumber      String             @unique
  aadhaarNumber      String?
  verificationStatus VerificationStatus @default(PENDING)
  availabilityStatus AvailabilityStatus @default(OFFLINE)
  currentLat         Float?
  currentLng         Float?
  lastActiveAt       DateTime?
  idleSince          DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user               User               @relation(fields: [userId], references: [id])
  vehicles           Vehicle[]
  trips              Trip[]
  queuedTrips        Trip[]             @relation("QueuedDriverTrips")
}

model Vehicle {
  id              String      @id @default(uuid())
  driverProfileId String
  type            VehicleType
  capacityKg      Int
  insuranceStatus String
  createdAt       DateTime    @default(now())

  driverProfile   DriverProfile @relation(fields: [driverProfileId], references: [id])
}

model Order {
  id                String       @id @default(uuid())
  customerId        String
  pickupAddress     String
  pickupLat         Float
  pickupLng         Float
  dropAddress       String
  dropLat           Float
  dropLng           Float
  scheduledAt       DateTime?
  vehicleType       VehicleType
  goodsDescription  String
  goodsType         String?
  goodsValue        Decimal      @db.Decimal(12, 2)
  insuranceSelected InsurancePlan @default(NONE)
  insurancePremium  Decimal      @default(0) @db.Decimal(10, 2)
  gstin             String?
  invoiceValue      Decimal?     @db.Decimal(12, 2)
  hsnCode           String?
  ewayBillNumber    String?
  status            OrderStatus  @default(CREATED)
  estimatedPrice    Decimal      @db.Decimal(10, 2)
  finalPrice        Decimal?     @db.Decimal(10, 2)
  waitingCharge     Decimal      @default(0) @db.Decimal(10, 2)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  customer          User         @relation("CustomerOrders", fields: [customerId], references: [id])
  trip              Trip?
  payment           Payment?
}

model Trip {
  id                String      @id @default(uuid())
  orderId           String      @unique
  driverId          String
  queuedDriverId    String?
  status            TripStatus  @default(ASSIGNED)
  etaMinutes        Int?
  pickupTime        DateTime?
  loadingStart      DateTime?
  loadingEnd        DateTime?
  deliveryTime      DateTime?
  distanceKm        Float?
  durationMinutes   Int?
  waitingCharge     Decimal     @default(0) @db.Decimal(10, 2)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  order             Order       @relation(fields: [orderId], references: [id])
  driver            DriverProfile @relation(fields: [driverId], references: [id])
  queuedDriver      DriverProfile? @relation("QueuedDriverTrips", fields: [queuedDriverId], references: [id])
  rating            Rating?
}

model Rating {
  id              String   @id @default(uuid())
  tripId           String  @unique
  driverRating     Float
  customerRating   Float?
  review           String?
  createdAt        DateTime @default(now())

  trip             Trip    @relation(fields: [tripId], references: [id])
}

model PricingRule {
  id                  String   @id @default(uuid())
  minDriverRating     Float
  maxDriverRating     Float
  multiplier          Float
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Payment {
  id                String          @id @default(uuid())
  orderId            String         @unique
  provider           PaymentProvider
  amount             Decimal        @db.Decimal(10, 2)
  status             PaymentStatus  @default(PENDING)
  providerRef        String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  order              Order          @relation(fields: [orderId], references: [id])
}
