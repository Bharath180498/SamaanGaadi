generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  DRIVER
  ADMIN
}

enum VehicleType {
  THREE_WHEELER
  MINI_TRUCK
  TRUCK
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AvailabilityStatus {
  OFFLINE
  ONLINE
  BUSY
}

enum OrderStatus {
  CREATED
  MATCHING
  ASSIGNED
  AT_PICKUP
  LOADING
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum InsurancePlan {
  NONE
  BASIC
  PREMIUM
  HIGH_VALUE
}

enum TripStatus {
  ASSIGNED
  DRIVER_EN_ROUTE
  ARRIVED_PICKUP
  LOADING
  IN_TRANSIT
  COMPLETED
  CANCELLED
}

enum PaymentProvider {
  RAZORPAY
  CASHFREE
  STRIPE
  UPI
  WALLET
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
}

enum AuthChannel {
  SMS
  WHATSAPP
}

enum AuthSessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum OnboardingStatus {
  NOT_STARTED
  IN_PROGRESS
  SUBMITTED
  APPROVED
  REJECTED
}

enum KycDocType {
  AADHAAR_FRONT
  AADHAAR_BACK
  LICENSE_FRONT
  LICENSE_BACK
  RC_FRONT
  RC_BACK
  SELFIE
}

enum KycDocStatus {
  UPLOADED
  VERIFIED
  REJECTED
}

enum KycVerificationStatus {
  NOT_STARTED
  PENDING
  IN_REVIEW
  VERIFIED
  REJECTED
  INCONCLUSIVE
}

enum TripOfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
  CANCELLED
}

enum VehicleMatchType {
  EXACT
  UPGRADE
}

enum DriverPaymentMethodType {
  UPI_QR
  UPI_VPA
}

enum DriverSubscriptionPlan {
  GO
  PRO
  ENTERPRISE
}

enum DriverSubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
}

enum DriverEnterpriseRequestStatus {
  PENDING
  CONTACTED
  APPROVED
  REJECTED
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_FOR_USER
  RESOLVED
}

enum SupportMessageSenderType {
  USER
  ADMIN
  SYSTEM
}

enum AgentMessageRole {
  ADMIN
  ASSISTANT
  SYSTEM
}

enum AgentRunStatus {
  RUNNING
  WAITING_CONFIRMATION
  COMPLETED
  FAILED
}

enum AgentActionType {
  READ
  WRITE
}

enum AgentActionStatus {
  PROPOSED
  CONFIRMED
  EXECUTED
  REJECTED
  FAILED
}

enum AgentRiskLevel {
  LOW
  MEDIUM
  HIGH
}

model User {
  id           String         @id @default(uuid())
  name         String
  phone        String         @unique
  email        String?        @unique
  passwordHash String?
  role         UserRole
  rating       Float          @default(5)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  customerOrders Order[]      @relation("CustomerOrders")
  driverProfile  DriverProfile?
  otpSessions    OtpSession[]
  authSessions   AuthSession[]
  onboarding     DriverOnboarding?
  kycDocuments   KycDocument[]
  kycVerifications KycVerification[]
  reviewedKycVerifications KycVerification[] @relation("KycReviewedByAdmin")
  driverPaymentMethods DriverPaymentMethod[]
  supportTicketsRequested SupportTicket[] @relation("SupportTicketsRequested")
  supportMessagesSent SupportTicketMessage[] @relation("SupportMessagesSent")
  customerPushTokens CustomerPushToken[]
  adminAgentSessions AgentSession[] @relation("AdminAgentSessions")
  adminAgentMessages AgentMessage[] @relation("AdminAgentMessages")
  adminAgentRuns AgentRun[] @relation("AdminAgentRuns")
  adminAgentActions AgentAction[] @relation("AdminAgentActions")
  confirmedAgentActions AgentAction[] @relation("AdminAgentActionConfirmations")
}

model DriverProfile {
  id                 String             @id @default(uuid())
  userId             String             @unique
  vehicleType        VehicleType
  vehicleNumber      String             @unique
  licenseNumber      String             @unique
  aadhaarNumber      String?
  subscriptionPlan   DriverSubscriptionPlan   @default(GO)
  subscriptionStatus DriverSubscriptionStatus @default(ACTIVE)
  trialEndsAt        DateTime?
  verificationStatus VerificationStatus @default(PENDING)
  availabilityStatus AvailabilityStatus @default(OFFLINE)
  currentLat         Float?
  currentLng         Float?
  lastActiveAt       DateTime?
  idleSince          DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user               User               @relation(fields: [userId], references: [id])
  vehicles           Vehicle[]
  trips              Trip[]
  queuedTrips        Trip[]             @relation("QueuedDriverTrips")
  pushTokens         DriverPushToken[]
  payoutAccount      DriverPayoutAccount?
  paymentMethods     DriverPaymentMethod[]
  tripOffers         TripOffer[]
  kycDocuments       KycDocument[]
  enterpriseRequests DriverEnterprisePlanRequest[]
  deliveryProofs     TripDeliveryProof[]

  @@index([availabilityStatus, vehicleType, lastActiveAt])
}

model Vehicle {
  id              String      @id @default(uuid())
  driverProfileId String
  type            VehicleType
  capacityKg      Int
  insuranceStatus String
  createdAt       DateTime    @default(now())

  driverProfile   DriverProfile @relation(fields: [driverProfileId], references: [id])
}

model Order {
  id                String       @id @default(uuid())
  customerId        String
  pickupAddress     String
  pickupLat         Float
  pickupLng         Float
  dropAddress       String
  dropLat           Float
  dropLng           Float
  scheduledAt       DateTime?
  vehicleType       VehicleType
  goodsDescription  String
  goodsType         String?
  goodsValue        Decimal      @db.Decimal(12, 2)
  insuranceSelected InsurancePlan @default(NONE)
  insurancePremium  Decimal      @default(0) @db.Decimal(10, 2)
  gstin             String?
  invoiceValue      Decimal?     @db.Decimal(12, 2)
  hsnCode           String?
  ewayBillNumber    String?
  status            OrderStatus  @default(CREATED)
  estimatedPrice    Decimal      @db.Decimal(10, 2)
  finalPrice        Decimal?     @db.Decimal(10, 2)
  waitingCharge     Decimal      @default(0) @db.Decimal(10, 2)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  customer          User         @relation("CustomerOrders", fields: [customerId], references: [id])
  trip              Trip?
  payment           Payment?
  tripOffers        TripOffer[]
  dispatchDecisions DispatchDecision[]
  supportTickets    SupportTicket[]
}

model Trip {
  id                String      @id @default(uuid())
  orderId           String      @unique
  driverId          String
  queuedDriverId    String?
  driverPreferredPaymentMethodId String?
  driverPreferredUpiId String?
  driverPreferredPaymentLabel String?
  driverPreferredUpiQrImageUrl String?
  status            TripStatus  @default(ASSIGNED)
  etaMinutes        Int?
  pickupTime        DateTime?
  loadingStart      DateTime?
  loadingEnd        DateTime?
  deliveryTime      DateTime?
  distanceKm        Float?
  durationMinutes   Int?
  waitingCharge     Decimal     @default(0) @db.Decimal(10, 2)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  order             Order       @relation(fields: [orderId], references: [id])
  driver            DriverProfile @relation(fields: [driverId], references: [id])
  queuedDriver      DriverProfile? @relation("QueuedDriverTrips", fields: [queuedDriverId], references: [id])
  rating            Rating?
  offers            TripOffer[]
  deliveryProof     TripDeliveryProof?
  supportTickets    SupportTicket[]
}

model TripDeliveryProof {
  id                  String        @id @default(uuid())
  tripId               String       @unique
  driverId             String
  receiverName         String
  receiverSignature    Json
  signatureCapturedAt  DateTime?
  photoFileKey         String
  photoUrl             String
  photoMimeType        String?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  trip                 Trip         @relation(fields: [tripId], references: [id], onDelete: Cascade)
  driver               DriverProfile @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@index([driverId, createdAt])
}

model Rating {
  id              String   @id @default(uuid())
  tripId           String  @unique
  driverRating     Float
  customerRating   Float?
  review           String?
  createdAt        DateTime @default(now())

  trip             Trip    @relation(fields: [tripId], references: [id])
}

model PricingRule {
  id                  String   @id @default(uuid())
  minDriverRating     Float
  maxDriverRating     Float
  multiplier          Float
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Payment {
  id                String          @id @default(uuid())
  orderId            String         @unique
  provider           PaymentProvider
  amount             Decimal        @db.Decimal(10, 2)
  status             PaymentStatus  @default(PENDING)
  providerRef        String?
  directPayToDriver  Boolean        @default(false)
  directUpiVpa       String?
  directUpiName      String?
  driverPaymentMethodId String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  order              Order          @relation(fields: [orderId], references: [id])
}

model SupportTicket {
  id               String               @id @default(uuid())
  requesterUserId  String
  requesterRole    UserRole
  orderId          String?
  tripId           String?
  subject          String
  description      String
  descriptionSourceLanguage     String?
  descriptionTranslatedEnglish  String?
  descriptionTranslationProvider String?
  status           SupportTicketStatus  @default(OPEN)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  resolvedAt       DateTime?

  requesterUser    User                 @relation("SupportTicketsRequested", fields: [requesterUserId], references: [id], onDelete: Cascade)
  order            Order?               @relation(fields: [orderId], references: [id], onDelete: SetNull)
  trip             Trip?                @relation(fields: [tripId], references: [id], onDelete: SetNull)
  messages         SupportTicketMessage[]

  @@index([requesterUserId, createdAt])
  @@index([status, createdAt])
  @@index([orderId])
  @@index([tripId])
}

model SupportTicketMessage {
  id               String                    @id @default(uuid())
  ticketId         String
  senderType       SupportMessageSenderType
  senderUserId     String?
  message          String
  sourceLanguage    String?
  translatedEnglish String?
  translationProvider String?
  createdAt        DateTime                  @default(now())

  ticket           SupportTicket             @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderUser       User?                     @relation("SupportMessagesSent", fields: [senderUserId], references: [id], onDelete: SetNull)
  attachments      SupportTicketMessageAttachment[]

  @@index([ticketId, createdAt])
  @@index([senderUserId, createdAt])
}

model SupportTicketMessageAttachment {
  id            String               @id @default(uuid())
  messageId     String
  fileKey       String
  fileUrl       String
  fileName      String?
  contentType   String?
  fileSizeBytes Int?
  createdAt     DateTime             @default(now())

  message       SupportTicketMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId, createdAt])
}

model AgentSession {
  id            String       @id @default(uuid())
  adminUserId   String
  title         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  lastActiveAt  DateTime     @default(now())

  adminUser     User         @relation("AdminAgentSessions", fields: [adminUserId], references: [id], onDelete: Cascade)
  messages      AgentMessage[]
  runs          AgentRun[]
  actions       AgentAction[]

  @@index([adminUserId, updatedAt])
}

model AgentMessage {
  id            String          @id @default(uuid())
  sessionId     String
  runId         String?
  adminUserId   String?
  role          AgentMessageRole
  content       String
  context       Json?
  createdAt     DateTime        @default(now())

  session       AgentSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  run           AgentRun?       @relation(fields: [runId], references: [id], onDelete: SetNull)
  adminUser     User?           @relation("AdminAgentMessages", fields: [adminUserId], references: [id], onDelete: SetNull)

  @@index([sessionId, createdAt])
  @@index([adminUserId, createdAt])
  @@index([runId, createdAt])
}

model AgentRun {
  id               String          @id @default(uuid())
  sessionId        String
  adminUserId      String
  status           AgentRunStatus  @default(RUNNING)
  model            String?
  promptTokens     Int?
  completionTokens Int?
  totalTokens      Int?
  toolCallsCount   Int             @default(0)
  errorMessage     String?
  trace            Json?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  completedAt      DateTime?

  session          AgentSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  adminUser        User            @relation("AdminAgentRuns", fields: [adminUserId], references: [id], onDelete: Cascade)
  messages         AgentMessage[]
  actions          AgentAction[]

  @@index([sessionId, createdAt])
  @@index([adminUserId, createdAt])
  @@index([status, createdAt])
}

model AgentAction {
  id                 String           @id @default(uuid())
  sessionId          String
  runId              String
  adminUserId        String
  confirmedByAdminId String?
  toolName           String
  actionType         AgentActionType
  status             AgentActionStatus @default(PROPOSED)
  riskLevel          AgentRiskLevel   @default(MEDIUM)
  requiresConfirmation Boolean        @default(true)
  argsJson           Json
  argsSummary        String?
  resultJson         Json?
  errorMessage       String?
  rejectionReason    String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  confirmedAt        DateTime?
  executedAt         DateTime?
  rejectedAt         DateTime?

  session            AgentSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  run                AgentRun         @relation(fields: [runId], references: [id], onDelete: Cascade)
  adminUser          User             @relation("AdminAgentActions", fields: [adminUserId], references: [id], onDelete: Cascade)
  confirmedByAdmin   User?            @relation("AdminAgentActionConfirmations", fields: [confirmedByAdminId], references: [id], onDelete: SetNull)

  @@index([runId, status])
  @@index([sessionId, createdAt])
  @@index([adminUserId, createdAt])
}

model OtpSession {
  id            String            @id @default(uuid())
  userId        String?
  phone         String
  role          UserRole?
  channel       AuthChannel       @default(SMS)
  otpCode       String
  status        AuthSessionStatus @default(ACTIVE)
  attempts      Int               @default(0)
  expiresAt     DateTime
  verifiedAt    DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  user          User?             @relation(fields: [userId], references: [id])

  @@index([phone, status, expiresAt])
}

model AuthSession {
  id             String            @id @default(uuid())
  userId         String
  accessToken    String
  refreshToken   String?
  status         AuthSessionStatus @default(ACTIVE)
  expiresAt      DateTime
  revokedAt      DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  user           User              @relation(fields: [userId], references: [id])

  @@index([userId, status, expiresAt])
}

model DriverOnboarding {
  id                String                @id @default(uuid())
  userId            String                @unique
  status            OnboardingStatus      @default(NOT_STARTED)
  fullName          String?
  phone             String?
  email             String?
  city              String?
  vehicleType       VehicleType?
  vehicleNumber     String?
  licenseNumber     String?
  aadhaarNumber     String?
  rcNumber          String?
  accountHolderName String?
  bankName          String?
  accountNumber     String?
  ifscCode          String?
  upiId             String?
  upiQrImageUrl     String?
  submittedAt       DateTime?
  approvedAt        DateTime?
  rejectedAt        DateTime?
  rejectionReason   String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  user              User                  @relation(fields: [userId], references: [id])
  documents         KycDocument[]
  verifications     KycVerification[]
}

model KycDocument {
  id                String        @id @default(uuid())
  userId            String
  onboardingId      String?
  driverProfileId   String?
  type              KycDocType
  status            KycDocStatus  @default(UPLOADED)
  fileKey           String
  fileUrl           String
  mimeType          String?
  fileSizeBytes     Int?
  providerRef       String?
  metadata          Json?
  rejectionReason   String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  user              User          @relation(fields: [userId], references: [id])
  onboarding        DriverOnboarding? @relation(fields: [onboardingId], references: [id])
  driverProfile     DriverProfile? @relation(fields: [driverProfileId], references: [id])

  @@index([userId, type, status])
}

model KycVerification {
  id                String                @id @default(uuid())
  userId            String
  onboardingId      String?
  provider          String
  providerRef       String?
  status            KycVerificationStatus @default(PENDING)
  riskSignals       Json?
  providerResponse  Json?
  reviewNotes       String?
  reviewedByAdminId String?
  reviewedAt        DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  user              User                  @relation(fields: [userId], references: [id])
  onboarding        DriverOnboarding?     @relation(fields: [onboardingId], references: [id])
  reviewedByAdmin   User?                 @relation("KycReviewedByAdmin", fields: [reviewedByAdminId], references: [id])

  @@index([userId, status, createdAt])
}

model DriverPayoutAccount {
  id                String      @id @default(uuid())
  driverId          String      @unique
  accountHolderName String
  bankName          String
  accountNumber     String
  ifscCode          String
  upiId             String?
  upiQrImageUrl     String?
  isVerified        Boolean     @default(false)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  driver            DriverProfile @relation(fields: [driverId], references: [id])
}

model DriverPaymentMethod {
  id          String                  @id @default(uuid())
  userId      String
  driverId    String?
  type        DriverPaymentMethodType @default(UPI_QR)
  label       String?
  upiId       String
  qrImageUrl  String?
  isPreferred Boolean                 @default(false)
  isActive    Boolean                 @default(true)
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  user        User                    @relation(fields: [userId], references: [id])
  driver      DriverProfile?          @relation(fields: [driverId], references: [id])

  @@index([userId, isActive, isPreferred])
  @@index([driverId, isActive, isPreferred])
}

model DriverPushToken {
  id             String        @id @default(uuid())
  driverId       String
  token          String        @unique
  platform       String
  appVersion     String?
  deviceId       String?
  isActive       Boolean       @default(true)
  lastSeenAt     DateTime      @default(now())
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  driver         DriverProfile @relation(fields: [driverId], references: [id])

  @@index([driverId, isActive])
}

model CustomerPushToken {
  id             String   @id @default(uuid())
  customerId     String
  token          String   @unique
  platform       String
  appVersion     String?
  deviceId       String?
  isActive       Boolean  @default(true)
  lastSeenAt     DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  customer       User     @relation(fields: [customerId], references: [id])

  @@index([customerId, isActive])
}

model DriverEnterprisePlanRequest {
  id           String                       @id @default(uuid())
  driverId     String
  status       DriverEnterpriseRequestStatus @default(PENDING)
  contactName  String?
  contactPhone String?
  city         String?
  fleetSize    Int?
  notes        String?
  createdAt    DateTime                     @default(now())
  updatedAt    DateTime                     @updatedAt
  resolvedAt   DateTime?

  driver       DriverProfile                @relation(fields: [driverId], references: [id])

  @@index([driverId, status, createdAt])
}

model TripOffer {
  id                String          @id @default(uuid())
  orderId            String
  tripId             String?
  driverId           String
  status             TripOfferStatus @default(PENDING)
  expiresAt          DateTime
  respondedAt        DateTime?
  score              Float
  scoreBreakdown     Json?
  routeEtaMinutes    Int
  distanceKm         Float?
  vehicleMatchType   VehicleMatchType @default(EXACT)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  order              Order           @relation(fields: [orderId], references: [id])
  trip               Trip?           @relation(fields: [tripId], references: [id])
  driver             DriverProfile   @relation(fields: [driverId], references: [id])

  @@index([driverId, status, expiresAt])
  @@index([orderId, status, createdAt])
}

model RouteEtaCache {
  id              String       @id @default(uuid())
  originCell      String
  destinationCell String
  vehicleType     VehicleType
  provider        String
  etaMinutes      Int
  distanceMeters  Int?
  expiresAt       DateTime
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([originCell, destinationCell, vehicleType])
  @@index([originCell, destinationCell, vehicleType, expiresAt])
}

model DispatchDecision {
  id               String           @id @default(uuid())
  orderId          String
  selectedDriverId String?
  offerId          String?
  assignmentMode   String
  routeEtaMinutes  Int?
  vehicleMatchType VehicleMatchType?
  totalScore       Float?
  decisionPayload  Json?
  reason           String?
  createdAt        DateTime         @default(now())

  order            Order            @relation(fields: [orderId], references: [id])

  @@index([orderId, createdAt])
  @@index([selectedDriverId, createdAt])
}
