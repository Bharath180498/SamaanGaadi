{
  "expo": {
    "name": "Qargo Driver",
    "slug": "qargo-driver",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#FFF8F1"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.qargo.driver",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Qargo Driver uses your location for trip navigation and live tracking.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Qargo Driver needs background location while you are online for dispatch and safety."
      }
    },
    "android": {
      "package": "com.qargo.driver",
      "permissions": [
        "POST_NOTIFICATIONS",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION"
      ]
    },
    "plugins": [
      "expo-notifications",
      "expo-asset"
    ],
    "extra": {
      "apiBaseUrl": "https://backend-production-0ee70.up.railway.app/api",
      "supportPhone": "9844259899"
    }
  }
}
